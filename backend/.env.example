GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_STT_MODEL=whisper-large-v3-turbo

# LLM providers (Groq is NOT used for LLM — only STT/TTS)
CEREBRAS_API_KEY=csk_xxxxxxxxxxxxxxxxxxxxx
CEREBRAS_MODEL=gpt-oss-120b
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxx
MISTRAL_MODEL=mistral-medium-latest
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=300

TTS_MODEL=KittenML/kitten-tts-nano-0.1
TTS_SPEED=1.0
TTS_LAZY_LOAD=true
TTS_ALLOW_MOCK_FALLBACK=false

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Security
ADMIN_API_KEY=              # Set a strong key; auto-generated if empty
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8000
MAX_AUDIO_BYTES=10485760    # 10 MB
MAX_TEXT_LENGTH=2000
WS_AUDIO_RATE_LIMIT=20      # per minute per connection
WS_TEXT_RATE_LIMIT=30        # per minute per connection
